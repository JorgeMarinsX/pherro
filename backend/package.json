{
  "name": "pherro-backend",
  "private": true,
  "version": "0.0.1",
  "description": "Pherro NestJS backend (Bun runtime, Fastify platform).",
  "scripts": {
    "dev": "prisma migrate deploy && bun --bun --watch run src/main.ts",
    "start": "prisma migrate deploy && bun --bun run src/main.ts",
    "build": "nest build",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/platform-fastify": "^10.4.0",
    "@prisma/client": "^5.22.0",
    "cache-manager": "^5.7.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@types/bun": "latest",
    "prisma": "^5.22.0",
    "typescript": "^5.6.0"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  },
  "trustedDependencies": [
    "@prisma/client",
    "prisma"
  ]
}
