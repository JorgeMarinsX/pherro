// Pherro — Prisma schema. Managed migrations only (never db push).
// Multi-tenant SaaS: ONE shared Postgres. Every owned row carries tenantId.
// Isolation = Prisma auto-scope extension + Postgres RLS + explicit filters.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------- Tenant ----------------

model Tenant {
  id           String       @id @default(cuid())
  slug         String       @unique // → <slug>.pherro.app
  name         String
  customDomain String?      @unique // → cars.acme.com
  domainStatus DomainStatus @default(NONE)
  plan         String       @default("free")
  status       TenantStatus @default(ACTIVE)
  // Billing (Asaas): document + provider ids. Customer created best-effort at signup.
  cpfCnpj             String?
  asaasCustomerId     String? @unique
  asaasSubscriptionId String? @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users                User[]
  shopConfig           ShopConfig?
  whatsappNumbers      WhatsappNumber[]
  vehicles             Vehicle[]
  vehiclePhotos        VehiclePhoto[]
  attributeDefinitions AttributeDefinition[]
  vehicleAttributes    VehicleAttribute[]
  leads                Lead[]
  leadVehicleInterests LeadVehicleInterest[]
  emailCampaigns       EmailCampaign[]
  campaignRecipients   CampaignRecipient[]
}

enum DomainStatus {
  NONE
  PENDING
  VERIFIED
  ACTIVE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

// Billing webhook dedupe ledger (delivery is at-least-once).
// Platform-owned: no tenantId, no RLS — like Tenant.
model AsaasWebhookEvent {
  id         String   @id // provider event id
  event      String
  payload    Json
  receivedAt DateTime @default(now())
}

// ---------------- Users ----------------

model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  role         UserRole  @default(STAFF)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  @@unique([tenantId, email])
  @@index([tenantId, email])
}

enum UserRole {
  ADMIN
  STAFF
}

// Cross-tenant operator (platform owner). No tenantId, no RLS — like Tenant.
model PlatformAdmin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
}

// ---------------- Shop config ----------------

model ShopConfig {
  id              String           @id @default(cuid())
  tenantId        String           @unique
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopName        String
  logoUrl         String?
  description     String?          @db.Text
  address         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  whatsappNumbers WhatsappNumber[]
}

model WhatsappNumber {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label        String
  description  String?    @db.Text
  number       String
  isActive     Boolean    @default(false)
  shopConfigId String
  shopConfig   ShopConfig @relation(fields: [shopConfigId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  vehicles     Vehicle[]

  @@index([tenantId, shopConfigId, isActive])
}

// ---------------- Vehicles ----------------

model Vehicle {
  id               String                @id @default(cuid())
  tenantId         String
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug             String
  make             String
  model            String
  year             Int
  price            Int
  mileage          Int
  color            String
  description      String?               @db.Text
  transmission     Transmission
  fuelType         FuelType
  status           VehicleStatus         @default(ACTIVE)
  whatsappNumberId String?
  whatsappNumber   WhatsappNumber?       @relation(fields: [whatsappNumberId], references: [id], onDelete: SetNull)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  photos           VehiclePhoto[]
  attributes       VehicleAttribute[]
  leadInterests    LeadVehicleInterest[]

  @@unique([tenantId, slug])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, status, price])
  @@index([tenantId, status, year])
  @@index([tenantId, make, model])
}

model VehiclePhoto {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url       String
  position  Int
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId, position])
}

// ---------------- Attributes ----------------

model AttributeDefinition {
  id        String             @id @default(cuid())
  tenantId  String
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  icon      String? // Iconify name, e.g. "i-lucide-snowflake"
  type      AttributeType
  options   Json?
  createdAt DateTime           @default(now())
  vehicles  VehicleAttribute[]

  @@unique([tenantId, slug])
}

model VehicleAttribute {
  tenantId              String
  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicleId             String
  attributeDefinitionId String
  value                 String
  vehicle               Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  attributeDefinition   AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Cascade)

  @@id([vehicleId, attributeDefinitionId])
  @@index([tenantId])
}

// ---------------- Leads / CRM ----------------

model Lead {
  id               String                @id @default(cuid())
  tenantId         String
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  phone            String
  email            String?
  notes            String?               @db.Text
  source           LeadSource
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  vehicleInterests LeadVehicleInterest[]
  campaignEmails   CampaignRecipient[]

  @@index([tenantId, phone])
  @@index([tenantId, createdAt(sort: Desc)])
}

model LeadVehicleInterest {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId    String
  vehicleId String
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([leadId, vehicleId])
  @@index([tenantId])
}

// ---------------- E-mail ----------------

// Transactional templates (welcome, password recovery, new lead...).
// Platform-owned: no tenantId, no RLS — edited only in the platform panel.
model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  subject   String
  html      String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Marketing campaign (CRM) — tenant-owned, sent to leads with e-mail.
model EmailCampaign {
  id             String              @id @default(cuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  subject        String              @default("")
  html           String              @default("") @db.Text
  status         CampaignStatus      @default(DRAFT)
  recipientCount Int                 @default(0)
  sentCount      Int                 @default(0)
  failedCount    Int                 @default(0)
  sentAt         DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  recipients     CampaignRecipient[]

  @@index([tenantId, createdAt(sort: Desc)])
}

model CampaignRecipient {
  id         String          @id @default(cuid())
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   EmailCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId     String?
  lead       Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  email      String
  name       String
  status     RecipientStatus @default(PENDING)
  resendId   String?
  error      String?
  createdAt  DateTime        @default(now())

  @@unique([campaignId, email])
  @@index([tenantId, campaignId, status])
}

enum CampaignStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
}

// ---------------- Enums ----------------

enum Transmission {
  MANUAL
  AUTOMATIC
  CVT
}

enum FuelType {
  FLEX
  GASOLINE
  ETHANOL
  DIESEL
  ELECTRIC
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
}

enum AttributeType {
  BOOLEAN
  ENUM
  TEXT
}

enum LeadSource {
  MANUAL
  FORM
}
