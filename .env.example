# Pherro — per-tenant env template. Copy to .env and fill in all __REPLACE_ME__ values.
# NEVER commit .env to git.
#
# To generate secrets:
#   JWT_SECRET / POSTGRES_PASSWORD: openssl rand -hex 32
#   SECRET_KEY_BASE:                openssl rand -base64 64
#   PG_META_CRYPTO_KEY:             openssl rand -hex 16  (32 hex chars)
#   ANON_KEY / SERVICE_ROLE_KEY:    https://supabase.com/docs/guides/self-hosting#api-keys
#
# IMPORTANT: POSTGRES_PASSWORD and JWT_SECRET are baked into the Postgres
# data volume on first boot. To rotate them later you MUST reset the volume:
#   docker compose down -v && docker compose up -d

############
# Tenant
############

TENANT_SLUG=dev
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

############
# Secrets
############

POSTGRES_PASSWORD=__REPLACE_ME__
JWT_SECRET=__REPLACE_ME__
ANON_KEY=__REPLACE_ME__
SERVICE_ROLE_KEY=__REPLACE_ME__

# Used by Realtime and Studio
SECRET_KEY_BASE=__REPLACE_ME_64_CHARS__

# Used by postgres-meta
PG_META_CRYPTO_KEY=__REPLACE_ME_32_CHARS__

# Asymmetric keys (optional — leave blank to use legacy HS256 only)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

############
# Database
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# URLs
############

SUPABASE_PUBLIC_URL=http://localhost:8000

############
# Auth
############

JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

############
# SMTP (optional — leave blank to skip email delivery)
############

SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Pherro

############
# PostgREST / Studio
############

PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

############
# Studio / Dashboard
############

DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=__REPLACE_ME__

############
# Storage
############

GLOBAL_S3_BUCKET=stub
REGION=local

############
# Kong ports
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
