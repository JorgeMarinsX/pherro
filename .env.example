# Pherro — per-tenant env template. Copy to .env and fill in __REPLACE_ME__ values.
# NEVER commit .env to git.
#
# Generate secrets:
#   POSTGRES_PASSWORD: openssl rand -hex 32
#
# IMPORTANT: POSTGRES_PASSWORD is baked into the Postgres data volume on first
# boot. To rotate it later you MUST reset the volume:
#   docker compose down -v && docker compose up -d

############
# Tenant
############

TENANT_SLUG=dev
SITE_URL=http://localhost:3000

# Base domain for subdomain→tenant resolution (<slug>.APP_BASE_DOMAIN).
APP_BASE_DOMAIN=pherro.app

############
# Database
############

POSTGRES_PASSWORD=__REPLACE_ME__
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# Backend URLs
############

# Used by Nuxt SSR (server-side, container-to-container)
BACKEND_URL=http://backend:3001

# Used by Nuxt client (browser-side, host-to-container via published port)
NUXT_PUBLIC_BACKEND_URL=http://localhost:3001

############
# Auth (Layer 1 — shared service token)
############

# Shared secret between Nuxt SSR and NestJS backend. Per-tenant.
# Generate: openssl rand -hex 32
# NEVER expose via runtimeConfig.public — SSR-only.
BACKEND_ADMIN_TOKEN=__REPLACE_ME__

# Comma-separated allowed CORS origins for backend.
CORS_ORIGINS=http://localhost:3000

############
# Auth (Layer 3 — Backend-owned identity)
############

# Seeded platform admin (cross-tenant operator). Created by prisma/seed.ts.
PLATFORM_ADMIN_EMAIL=platform@pherro.local
PLATFORM_ADMIN_PASSWORD=__REPLACE_ME__

# Seeded per-tenant admin for the TENANT_SLUG tenant.
TENANT_ADMIN_EMAIL=admin@pherro.local
TENANT_ADMIN_PASSWORD=__REPLACE_ME__

# JWT signing secret (HS256). Backend-only.
# Generate: openssl rand -hex 32
JWT_SECRET=__REPLACE_ME__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Nuxt SSR sealed cookie HMAC key. SSR-only.
# Generate: openssl rand -hex 32
SESSION_SECRET=__REPLACE_ME__
