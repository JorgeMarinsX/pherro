# Pherro — per-tenant env template. Copy to .env and fill in __REPLACE_ME__ values.
# NEVER commit .env to git.
#
# Generate secrets:
#   POSTGRES_PASSWORD: openssl rand -hex 32
#
# IMPORTANT: POSTGRES_PASSWORD is baked into the Postgres data volume on first
# boot. To rotate it later you MUST reset the volume:
#   docker compose down -v && docker compose up -d

############
# Tenant
############

# Dev-only: slug seeded on boot AND the fallback tenant when the request host
# matches no tenant (e.g. localhost). Prod resolves tenants from Host only.
TENANT_SLUG=dev
SITE_URL=http://localhost:3000

# Base domain for subdomain→tenant resolution (<slug>.APP_BASE_DOMAIN).
# Apex/www serve the product landing page + signup; app.* the platform dashboard.
# Dev: localhost (tenant sites at <slug>.localhost:3000). Prod: pherro.app.
APP_BASE_DOMAIN=localhost

############
# Database
############

POSTGRES_PASSWORD=__REPLACE_ME__
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Non-superuser role the app connects as (superusers bypass RLS — never run
# the app as postgres). Created at volume init by db/init/01-app-role.sh;
# rotating it also needs a volume reset.
APP_DB_PASSWORD=__REPLACE_ME__

############
# Backend URLs
############

# Used by Nuxt SSR (server-side, container-to-container). The browser never
# talks to the backend directly — everything proxies through the Nuxt BFF.
BACKEND_URL=http://backend:3001

############
# Auth (Layer 1 — shared service token)
############

# Shared secret between Nuxt SSR and NestJS backend. Per-tenant.
# Generate: openssl rand -hex 32
# NEVER expose via runtimeConfig.public — SSR-only.
BACKEND_ADMIN_TOKEN=__REPLACE_ME__

# Comma-separated allowed CORS origins for backend.
CORS_ORIGINS=http://localhost:3000

############
# Auth (Layer 3 — Backend-owned identity)
############

# Seeded platform admin (cross-tenant operator). Created by prisma/seed.ts.
PLATFORM_ADMIN_EMAIL=platform@pherro.local
PLATFORM_ADMIN_PASSWORD=__REPLACE_ME__

# Seeded per-tenant admin for the TENANT_SLUG tenant.
TENANT_ADMIN_EMAIL=admin@pherro.local
TENANT_ADMIN_PASSWORD=__REPLACE_ME__

# JWT signing secret (HS256). Backend-only.
# Generate: openssl rand -hex 32
JWT_SECRET=__REPLACE_ME__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Nuxt SSR sealed cookie HMAC key. SSR-only.
# Generate: openssl rand -hex 32
SESSION_SECRET=__REPLACE_ME__

############
# Billing — Asaas
############

# API key. Leave empty until generated (billing calls are skipped while empty).
# Sandbox keys start with $aact_hmlg_, production with $aact_prod_ — the key
# must match ASAAS_BASE_URL's environment or Asaas returns 401.
ASAAS_API_KEY=

# Sandbox: https://api-sandbox.asaas.com/v3 | Production: https://api.asaas.com/v3
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3

# Shared secret validated on incoming Asaas webhooks (asaas-access-token header).
# Generate: openssl rand -hex 32 — paste the same value in the Asaas webhook config.
ASAAS_WEBHOOK_TOKEN=

############
# E-mail — Resend
############

# API key (https://resend.com/api-keys). Leave empty until generated — e-mail
# sends are skipped while empty (signup/leads still work; campaigns refuse to send).
RESEND_API_KEY=

# Sender. onboarding@resend.dev works without domain verification (delivers only
# to your own Resend account inbox). After verifying the domain in Resend, use
# e.g. "Pherro <no-reply@pherro.app>".
RESEND_FROM=Pherro <onboarding@resend.dev>

############
# Uploads (vehicle photos)
############

# Max concurrent image transforms (sharp). Uploads queue past this — keeps a
# photo burst from starving CPU for other tenants. ~half the vCPUs is a good cap.
UPLOAD_TRANSFORM_CONCURRENCY=4

############
# Production only (docker-compose.prod.yml — Traefik TLS)
############

# Let's Encrypt registration e-mail (expiry notices).
TRAEFIK_ACME_EMAIL=ops@pherro.app

# DNS provider for the *.APP_BASE_DOMAIN wildcard cert (DNS-01 challenge).
# Provider list + required env vars: https://doc.traefik.io/traefik/https/acme/#providers
TRAEFIK_DNS_PROVIDER=cloudflare
CF_DNS_API_TOKEN=__REPLACE_ME__
